DATABASE_URL=postgres://salud_financiera:change-me@localhost:5433/salud_financiera
PORT=3001

# Opcional: si la pones, la API exige "Authorization: Bearer <valor>" en todas las
# rutas salvo /health. Déjala sin poner para el uso personal habitual por Tailscale
# (sin fricción); actívala solo si vas a exponer la API más allá de tu red privada.
# El frontend necesita el mismo valor en VITE_API_TOKEN (ver .env.example de la raíz).
API_TOKEN=

# Base de datos separada para los tests de integración (nunca la real): créala con
# `createdb` o `psql -c "CREATE DATABASE salud_financiera_test"` y aplícale las
# migraciones con TEST_DATABASE_URL=... npm run migrate:up.
TEST_DATABASE_URL=postgres://salud_financiera:change-me@localhost:5433/salud_financiera_test
