<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Job de launchd que ejecuta scripts/backup-db.sh una vez al día.

  Este fichero es la PLANTILLA que vive en el repo. La copia realmente
  instalada está en ~/Library/LaunchAgents/com.saludfinanciera.dbbackup.plist
  (fuera del repo, con la ruta absoluta del usuario). Instálala/actualízala
  con scripts/install-backup-schedule.sh.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.saludfinanciera.dbbackup</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_DIR__/scripts/backup-db.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>

  <!-- Se ejecuta todos los días a las 09:00 (hora local del Mac).
       Si el Mac está apagado/dormido a esa hora, launchd lo lanza en cuanto
       el equipo se despierta (comportamiento estándar de StartCalendarInterval
       en macOS: no hay que activar nada extra para eso). -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:__HOME__/.orbstack/bin</string>
  </dict>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/backups/backup.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/backups/backup.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
